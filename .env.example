# Exoplanet Explorer — Environment Variables
# Copy this file to .env.secret and fill in the values.

# Application
NAME=Exoplanet Explorer
DEBUG=true
API_KEY=dev-api-key

# CORS — origins allowed to call the backend
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8080"]

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=exoplanets
DB_USER=exoplanet_user
DB_PASSWORD=exoplanet_pass

# Port mappings
DB_PORT_EXTERNAL=5432
BACKEND_PORT_EXTERNAL=8000
CLIENT_PORT_EXTERNAL=3000
CADDY_HTTP_PORT=8080
CADDY_HTTPS_PORT=8443

# V2 — LLM (OpenAI-compatible)
# LLM_API_KEY=
# LLM_API_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
